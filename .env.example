# ============================================================
# ModulCA Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ---------- Database (Supabase PostgreSQL) ----------
DATABASE_URL="postgresql://user:password@host:5432/modulca?schema=public"

# ---------- Authentication (NextAuth.js) ----------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ---------- Mapbox ----------
NEXT_PUBLIC_MAPBOX_TOKEN="your-mapbox-token-here"

# ---------- Supabase ----------
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# ---------- Stripe Payments ----------
# Get keys from https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."

# Webhook secret from Stripe Dashboard > Developers > Webhooks
# Endpoint URL: https://www.modulca.eu/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs — create in Stripe Dashboard > Products
# Product: "ModulCA Premium" (€29/mo, €290/yr)
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_YEARLY="price_..."

# Product: "ModulCA Architect" (€79/mo, €790/yr)
NEXT_PUBLIC_STRIPE_PRICE_ARCHITECT_MONTHLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_ARCHITECT_YEARLY="price_..."

# Product: "ModulCA Constructor" (€149/mo, €1490/yr)
NEXT_PUBLIC_STRIPE_PRICE_CONSTRUCTOR_MONTHLY="price_..."
NEXT_PUBLIC_STRIPE_PRICE_CONSTRUCTOR_YEARLY="price_..."

# ---------- Resend (Email) ----------
RESEND_API_KEY="re_..."
# After verifying modulca.eu domain in Resend, use: "ModulCA <noreply@modulca.eu>"
RESEND_FROM_EMAIL="ModulCA <onboarding@resend.dev>"

# ---------- AI Render Providers ----------
# See docs/AI_PROVIDERS.md for full list
POLLINATIONS_API_KEY=""
TOGETHER_API_KEY=""
PRODIA_API_KEY=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""

# ---------- Application ----------
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ModulCA"
